version: 1.0.3
description: UPF Slice 1 (separate-UPF demo path)

pfcp:
  addr: upf-slice1
  nodeID: upf-slice1
  retransTimeout: 1s
  maxRetrans: 3

gtpu:
  forwarder: gtp5g
  ifList:
    - addr: upf-slice1
      type: N3

dnnList:
  - dnn: voip
    cidr: 10.60.0.0/16

logger:
  enable: true
  level: info
  reportCaller: false
